<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#121212"
    android:padding="16dp">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Erfolge"
        android:textColor="#FFFFFFFF"
        android:textSize="24sp"
        android:textStyle="bold"
        android:layout_marginBottom="8dp"/>

    <TextView
        android:id="@+id/achievementTitleDisplay"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Aktueller Titel: —"
        android:textColor="#9E9E9E"
        android:textSize="13sp"
        android:layout_marginBottom="8dp"/>

    <Button
        android:id="@+id/chooseTitleButton"
        android:layout_width="wrap_content"
        android:layout_height="36dp"
        android:background="@drawable/button_modern_bg"
        android:stateListAnimator="@animator/button_press"
        android:text="Titel wählen"
        android:textColor="#FFFFFFFF"
        android:textSize="12sp"
        android:layout_marginBottom="12dp"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        android:elevation="4dp"
                app:backgroundTint="@null"/>

    <ListView
        android:id="@+id/achievementListView"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:divider="@android:color/transparent"
        android:dividerHeight="8dp"/>

</LinearLayout>
