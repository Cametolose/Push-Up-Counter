<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#121212"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Header -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Einstellungen"
            android:textColor="#FFFFFFFF"
            android:textSize="24sp"
            android:textStyle="bold"
            android:layout_marginBottom="24dp"/>

        <!-- Profile section -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="PROFIL"
            android:textColor="#9E9E9E"
            android:textSize="12sp"
            android:letterSpacing="0.1"
            android:layout_marginBottom="8dp"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/quest_card_bg"
            android:padding="16dp"
            android:layout_marginBottom="24dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="12dp">

                <ImageView
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:src="@drawable/ic_nav_settings"
                    android:layout_marginEnd="12dp"/>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Benutzername"
                        android:textColor="#9E9E9E"
                        android:textSize="12sp"/>

                    <TextView
                        android:id="@+id/usernameDisplay"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Unbekannt"
                        android:textColor="#FFFFFFFF"
                        android:textSize="18sp"
                        android:textStyle="bold"/>
                </LinearLayout>
            </LinearLayout>

            <Button
                android:id="@+id/changeNameButton"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:background="@drawable/button_modern_bg"
                android:stateListAnimator="@animator/button_press"
                android:text="Namen \u00e4ndern"
                android:textColor="#FFFFFFFF"
                android:textSize="14sp"
                android:textStyle="bold"
                android:elevation="4dp"
                app:backgroundTint="@null"/>
        </LinearLayout>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="STATISTIKEN"
            android:textColor="#9E9E9E"
            android:textSize="12sp"
            android:letterSpacing="0.1"
            android:layout_marginBottom="8dp"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/quest_card_bg"
            android:padding="16dp"
            android:layout_marginBottom="24dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="12dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Gesamt Push-Ups"
                    android:textColor="#BBBBBB"
                    android:textSize="14sp"/>

                <TextView
                    android:id="@+id/statsTotalPushups"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0"
                    android:textColor="#FFFFFFFF"
                    android:textSize="14sp"
                    android:textStyle="bold"/>
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="12dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Heute"
                    android:textColor="#BBBBBB"
                    android:textSize="14sp"/>

                <TextView
                    android:id="@+id/statsDailyPushups"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0"
                    android:textColor="#FFFFFFFF"
                    android:textSize="14sp"
                    android:textStyle="bold"/>
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="12dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Diese Woche"
                    android:textColor="#BBBBBB"
                    android:textSize="14sp"/>

                <TextView
                    android:id="@+id/statsWeeklyPushups"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0"
                    android:textColor="#FFFFFFFF"
                    android:textSize="14sp"
                    android:textStyle="bold"/>
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="12dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Dieser Monat"
                    android:textColor="#BBBBBB"
                    android:textSize="14sp"/>

                <TextView
                    android:id="@+id/statsMonthlyPushups"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0"
                    android:textColor="#FFFFFFFF"
                    android:textSize="14sp"
                    android:textStyle="bold"/>
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="12dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Dieses Jahr"
                    android:textColor="#BBBBBB"
                    android:textSize="14sp"/>

                <TextView
                    android:id="@+id/statsYearlyPushups"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0"
                    android:textColor="#FFFFFFFF"
                    android:textSize="14sp"
                    android:textStyle="bold"/>
            </LinearLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#3E3E5E"
                android:layout_marginBottom="12dp"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="12dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Aktuelles Level"
                    android:textColor="#BBBBBB"
                    android:textSize="14sp"/>

                <TextView
                    android:id="@+id/statsLevel"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="1"
                    android:textColor="#81C784"
                    android:textSize="14sp"
                    android:textStyle="bold"/>
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="12dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Gesamt XP"
                    android:textColor="#BBBBBB"
                    android:textSize="14sp"/>

                <TextView
                    android:id="@+id/statsTotalXp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0"
                    android:textColor="#81C784"
                    android:textSize="14sp"
                    android:textStyle="bold"/>
            </LinearLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#3E3E5E"
                android:layout_marginBottom="12dp"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="12dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="\ud83d\udd25 Aktuelle Streak"
                    android:textColor="#BBBBBB"
                    android:textSize="14sp"/>

                <TextView
                    android:id="@+id/statsStreak"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0 Tage"
                    android:textColor="#FF9800"
                    android:textSize="14sp"
                    android:textStyle="bold"/>
            </LinearLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#3E3E5E"
                android:layout_marginBottom="12dp"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="12dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Quests abgeschlossen"
                    android:textColor="#BBBBBB"
                    android:textSize="14sp"/>

                <TextView
                    android:id="@+id/statsTotalQuests"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0"
                    android:textColor="#FFD600"
                    android:textSize="14sp"
                    android:textStyle="bold"/>
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="12dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="  \u2022 Leicht"
                    android:textColor="#9E9E9E"
                    android:textSize="13sp"/>

                <TextView
                    android:id="@+id/statsQuest1Count"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0"
                    android:textColor="#FFD600"
                    android:textSize="13sp"
                    android:textStyle="bold"/>
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="12dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="  \u2022 Mittel"
                    android:textColor="#9E9E9E"
                    android:textSize="13sp"/>

                <TextView
                    android:id="@+id/statsQuest2Count"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0"
                    android:textColor="#FFD600"
                    android:textSize="13sp"
                    android:textStyle="bold"/>
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="12dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="  \u2022 Schwer"
                    android:textColor="#9E9E9E"
                    android:textSize="13sp"/>

                <TextView
                    android:id="@+id/statsQuest3Count"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0"
                    android:textColor="#FFD600"
                    android:textSize="13sp"
                    android:textStyle="bold"/>
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Glücksrad gedreht"
                    android:textColor="#BBBBBB"
                    android:textSize="14sp"/>

                <TextView
                    android:id="@+id/statsBonusCount"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0"
                    android:textColor="#FFD600"
                    android:textSize="14sp"
                    android:textStyle="bold"/>
            </LinearLayout>
        </LinearLayout>

        <!-- Notifications section -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="BENACHRICHTIGUNGEN"
            android:textColor="#9E9E9E"
            android:textSize="12sp"
            android:letterSpacing="0.1"
            android:layout_marginBottom="8dp"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/quest_card_bg"
            android:padding="16dp"
            android:layout_marginBottom="24dp">

            <!-- Streak notification -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="12dp">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="\ud83d\udd25 Streak-Erinnerung"
                        android:textColor="#BBBBBB"
                        android:textSize="14sp"/>

                    <TextView
                        android:id="@+id/notificationTimeDisplay"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Zeit: 08:00"
                        android:textColor="#9E9E9E"
                        android:textSize="12sp"/>
                </LinearLayout>

                <Switch
                    android:id="@+id/switchStreakNotification"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:checked="true"/>
            </LinearLayout>

            <Button
                android:id="@+id/changeNotificationTimeButton"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:background="@drawable/button_modern_bg"
                android:stateListAnimator="@animator/button_press"
                android:text="Zeit \u00e4ndern"
                android:textColor="#FFFFFFFF"
                android:textSize="12sp"
                android:layout_marginBottom="12dp"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:elevation="4dp"
                app:backgroundTint="@null"/>

            <!-- Exact alarm permission row (Android 12+) -->
            <LinearLayout
                android:id="@+id/exactAlarmRow"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="16dp"
                android:visibility="gone">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/exactAlarmStatus"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="\u26a0 Exakte Alarme deaktiviert"
                        android:textColor="#FF9800"
                        android:textSize="12sp"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Benötigt für pünktliche Erinnerungen"
                        android:textColor="#9E9E9E"
                        android:textSize="11sp"/>
                </LinearLayout>

                <Button
                    android:id="@+id/exactAlarmSettingsButton"
                    android:layout_width="wrap_content"
                    android:layout_height="36dp"
                    android:background="@drawable/button_modern_bg"
                    android:stateListAnimator="@animator/button_press"
                    android:text="Aktivieren"
                    android:textColor="#FFFFFFFF"
                    android:textSize="11sp"
                    android:paddingStart="10dp"
                    android:paddingEnd="10dp"
                    android:elevation="4dp"
                    app:backgroundTint="@null"/>
            </LinearLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#3E3E5E"
                android:layout_marginBottom="12dp"/>

            <!-- Leaderboard notification -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="\ud83d\udcca Leaderboard-Updates"
                    android:textColor="#BBBBBB"
                    android:textSize="14sp"/>

                <Switch
                    android:id="@+id/switchLeaderboardNotification"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:checked="true"/>
            </LinearLayout>
        </LinearLayout>

        <!-- App info section -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="APP INFO"
            android:textColor="#9E9E9E"
            android:textSize="12sp"
            android:letterSpacing="0.1"
            android:layout_marginBottom="8dp"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/quest_card_bg"
            android:padding="16dp"
            android:layout_marginBottom="24dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Version"
                    android:textColor="#BBBBBB"
                    android:textSize="14sp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="127.0.0.1"
                    android:textColor="#FFFFFFFF"
                    android:textSize="14sp"/>
            </LinearLayout>
        </LinearLayout>

        <!-- Credits section -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="CREDITS"
            android:textColor="#9E9E9E"
            android:textSize="12sp"
            android:letterSpacing="0.1"
            android:layout_marginBottom="8dp"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/quest_card_bg"
            android:padding="16dp"
            android:layout_marginBottom="24dp">

            <Button
                android:id="@+id/creditsButton"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:background="@drawable/button_modern_bg"
                android:stateListAnimator="@animator/button_press"
                android:text="Credits anzeigen"
                android:textColor="#FFFFFFFF"
                android:textSize="14sp"
                android:textStyle="bold"
                android:elevation="4dp"
                app:backgroundTint="@null"/>
        </LinearLayout>

    </LinearLayout>
</ScrollView>
