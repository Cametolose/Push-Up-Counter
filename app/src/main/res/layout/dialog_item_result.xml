<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@drawable/quest_card_bg"
        android:padding="32dp"
        android:gravity="center_horizontal"
        android:minWidth="320dp">

        <!-- Item emoji (large) -->
        <TextView
            android:id="@+id/itemEmoji"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🎁"
            android:textSize="56sp"
            android:layout_marginBottom="16dp"/>

        <!-- Item name -->
        <TextView
            android:id="@+id/itemName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Item Name"
            android:textColor="#FFFFFFFF"
            android:textSize="24sp"
            android:textStyle="bold"
            android:layout_marginBottom="10dp"/>

        <!-- Item type badge -->
        <TextView
            android:id="@+id/itemTypeBadge"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="BUFF"
            android:textSize="12sp"
            android:textStyle="bold"
            android:background="@drawable/quest_card_bg"
            android:paddingLeft="14dp"
            android:paddingRight="14dp"
            android:paddingTop="4dp"
            android:paddingBottom="4dp"
            android:layout_marginBottom="16dp"/>

        <!-- Item description -->
        <TextView
            android:id="@+id/itemDescription"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Beschreibung"
            android:textColor="#BBBBBB"
            android:textSize="16sp"
            android:gravity="center"
            android:layout_marginBottom="12dp"/>

        <!-- Extra info (e.g. who trap was sent to) -->
        <TextView
            android:id="@+id/itemExtraInfo"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="#FFD600"
            android:textSize="15sp"
            android:gravity="center"
            android:layout_marginBottom="20dp"
            android:visibility="gone"/>

        <!-- Dismiss button -->
        <Button
            android:id="@+id/itemDismissButton"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:background="@drawable/button_increment_bg"
            android:stateListAnimator="@animator/button_press"
            android:text="Super!"
            android:textColor="#FFFFFF"
            android:textSize="17sp"
            android:textStyle="bold"
            android:elevation="4dp"/>

    </LinearLayout>
</ScrollView>
