<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/quest_card_bg"
    android:padding="24dp"
    android:gravity="center_horizontal">

    <!-- Item emoji (large) -->
    <TextView
        android:id="@+id/itemEmoji"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="🎁"
        android:textSize="48sp"
        android:layout_marginBottom="12dp"/>

    <!-- Item name -->
    <TextView
        android:id="@+id/itemName"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Item Name"
        android:textColor="#FFFFFFFF"
        android:textSize="22sp"
        android:textStyle="bold"
        android:layout_marginBottom="8dp"/>

    <!-- Item type badge -->
    <TextView
        android:id="@+id/itemTypeBadge"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="BUFF"
        android:textSize="11sp"
        android:textStyle="bold"
        android:background="@drawable/quest_card_bg"
        android:paddingLeft="12dp"
        android:paddingRight="12dp"
        android:paddingTop="3dp"
        android:paddingBottom="3dp"
        android:layout_marginBottom="12dp"/>

    <!-- Item description -->
    <TextView
        android:id="@+id/itemDescription"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Beschreibung"
        android:textColor="#BBBBBB"
        android:textSize="15sp"
        android:gravity="center"
        android:layout_marginBottom="8dp"/>

    <!-- Extra info (e.g. who trap was sent to) -->
    <TextView
        android:id="@+id/itemExtraInfo"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textColor="#FFD600"
        android:textSize="14sp"
        android:gravity="center"
        android:layout_marginBottom="16dp"
        android:visibility="gone"/>

    <!-- Dismiss button -->
    <Button
        android:id="@+id/itemDismissButton"
        android:layout_width="match_parent"
        android:layout_height="44dp"
        android:background="@drawable/button_increment_bg"
        android:text="Super!"
        android:textColor="#FFFFFF"
        android:textSize="16sp"
        android:textStyle="bold"
        android:elevation="4dp"/>

</LinearLayout>
