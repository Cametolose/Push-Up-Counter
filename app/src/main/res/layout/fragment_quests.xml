<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#121212"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Header -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="16dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Tägliche Aufgaben"
                android:textColor="#FFFFFFFF"
                android:textSize="24sp"
                android:textStyle="bold"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="↻ Mitternacht"
                android:textColor="#9E9E9E"
                android:textSize="12sp"/>
        </LinearLayout>

        <!-- Quest Card 1 — Leicht -->
        <LinearLayout
            android:id="@+id/questCard1"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/quest_card_bg"
            android:padding="16dp"
            android:layout_marginBottom="12dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="4dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="LEICHT"
                    android:textColor="#4CAF50"
                    android:textSize="10sp"
                    android:textStyle="bold"
                    android:background="@drawable/quest_card_bg"
                    android:paddingLeft="8dp"
                    android:paddingRight="8dp"
                    android:paddingTop="2dp"
                    android:paddingBottom="2dp"
                    android:layout_marginEnd="8dp"/>

                <TextView
                    android:id="@+id/questTitle1"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Anfänger"
                    android:textColor="#FFFFFFFF"
                    android:textSize="18sp"
                    android:textStyle="bold"/>

                <ImageView
                    android:id="@+id/questCheck1"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/ic_check"
                    android:visibility="gone"/>
            </LinearLayout>

            <TextView
                android:id="@+id/questDesc1"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Mache 20 Push-Ups heute"
                android:textColor="#BBBBBB"
                android:textSize="14sp"
                android:layout_marginBottom="10dp"/>

            <ProgressBar
                android:id="@+id/questProgress1"
                style="?android:attr/progressBarStyleHorizontal"
                android:layout_width="match_parent"
                android:layout_height="8dp"
                android:progressDrawable="@drawable/progress_bar_quest"
                android:max="1"
                android:progress="0"
                android:layout_marginBottom="6dp"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:id="@+id/questProgressText1"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Offen"
                    android:textColor="#9E9E9E"
                    android:textSize="12sp"/>

                <TextView
                    android:id="@+id/questReward1"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="+20 XP"
                    android:textColor="#7C4DFF"
                    android:textSize="12sp"
                    android:textStyle="bold"/>
            </LinearLayout>

            <Button
                android:id="@+id/questCompleteButton1"
                android:layout_width="match_parent"
                android:layout_height="40dp"
                android:background="@drawable/button_increment_bg"
                android:stateListAnimator="@animator/button_press"
                android:text="Erledigt ✓"
                android:textColor="#FFFFFF"
                android:textSize="13sp"
                android:textStyle="bold"
                android:layout_marginTop="8dp"
                android:elevation="4dp"
                android:visibility="visible"
                app:backgroundTint="@null"/>

        </LinearLayout>

        <!-- Quest Card 2 — Mittel -->
        <LinearLayout
            android:id="@+id/questCard2"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/quest_card_bg"
            android:padding="16dp"
            android:layout_marginBottom="12dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="4dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="MITTEL"
                    android:textColor="#FF9800"
                    android:textSize="10sp"
                    android:textStyle="bold"
                    android:background="@drawable/quest_card_bg"
                    android:paddingLeft="8dp"
                    android:paddingRight="8dp"
                    android:paddingTop="2dp"
                    android:paddingBottom="2dp"
                    android:layout_marginEnd="8dp"/>

                <TextView
                    android:id="@+id/questTitle2"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Fortgeschrittener"
                    android:textColor="#FFFFFFFF"
                    android:textSize="18sp"
                    android:textStyle="bold"/>

                <ImageView
                    android:id="@+id/questCheck2"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/ic_check"
                    android:visibility="gone"/>
            </LinearLayout>

            <TextView
                android:id="@+id/questDesc2"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Mache 50 Push-Ups heute"
                android:textColor="#BBBBBB"
                android:textSize="14sp"
                android:layout_marginBottom="10dp"/>

            <ProgressBar
                android:id="@+id/questProgress2"
                style="?android:attr/progressBarStyleHorizontal"
                android:layout_width="match_parent"
                android:layout_height="8dp"
                android:progressDrawable="@drawable/progress_bar_quest"
                android:max="1"
                android:progress="0"
                android:layout_marginBottom="6dp"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:id="@+id/questProgressText2"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Offen"
                    android:textColor="#9E9E9E"
                    android:textSize="12sp"/>

                <TextView
                    android:id="@+id/questReward2"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="+20 XP"
                    android:textColor="#7C4DFF"
                    android:textSize="12sp"
                    android:textStyle="bold"/>
            </LinearLayout>

            <Button
                android:id="@+id/questCompleteButton2"
                android:layout_width="match_parent"
                android:layout_height="40dp"
                android:background="@drawable/button_increment_bg"
                android:stateListAnimator="@animator/button_press"
                android:text="Erledigt ✓"
                android:textColor="#FFFFFF"
                android:textSize="13sp"
                android:textStyle="bold"
                android:layout_marginTop="8dp"
                android:elevation="4dp"
                android:visibility="visible"
                app:backgroundTint="@null"/>

        </LinearLayout>

        <!-- Quest Card 3 — Schwer -->
        <LinearLayout
            android:id="@+id/questCard3"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/quest_card_bg"
            android:padding="16dp"
            android:layout_marginBottom="12dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="4dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="SCHWER"
                    android:textColor="#F44336"
                    android:textSize="10sp"
                    android:textStyle="bold"
                    android:background="@drawable/quest_card_bg"
                    android:paddingLeft="8dp"
                    android:paddingRight="8dp"
                    android:paddingTop="2dp"
                    android:paddingBottom="2dp"
                    android:layout_marginEnd="8dp"/>

                <TextView
                    android:id="@+id/questTitle3"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Champion"
                    android:textColor="#FFFFFFFF"
                    android:textSize="18sp"
                    android:textStyle="bold"/>

                <ImageView
                    android:id="@+id/questCheck3"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/ic_check"
                    android:visibility="gone"/>
            </LinearLayout>

            <TextView
                android:id="@+id/questDesc3"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Mache 100 Push-Ups heute"
                android:textColor="#BBBBBB"
                android:textSize="14sp"
                android:layout_marginBottom="10dp"/>

            <ProgressBar
                android:id="@+id/questProgress3"
                style="?android:attr/progressBarStyleHorizontal"
                android:layout_width="match_parent"
                android:layout_height="8dp"
                android:progressDrawable="@drawable/progress_bar_quest"
                android:max="1"
                android:progress="0"
                android:layout_marginBottom="6dp"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:id="@+id/questProgressText3"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Offen"
                    android:textColor="#9E9E9E"
                    android:textSize="12sp"/>

                <TextView
                    android:id="@+id/questReward3"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="+20 XP"
                    android:textColor="#7C4DFF"
                    android:textSize="12sp"
                    android:textStyle="bold"/>
            </LinearLayout>

            <Button
                android:id="@+id/questCompleteButton3"
                android:layout_width="match_parent"
                android:layout_height="40dp"
                android:background="@drawable/button_increment_bg"
                android:stateListAnimator="@animator/button_press"
                android:text="Erledigt ✓"
                android:textColor="#FFFFFF"
                android:textSize="13sp"
                android:textStyle="bold"
                android:layout_marginTop="8dp"
                android:elevation="4dp"
                android:visibility="visible"
                app:backgroundTint="@null"/>

        </LinearLayout>

        <!-- Bonus XP Card -->
        <LinearLayout
            android:id="@+id/bonusCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/quest_card_locked_bg"
            android:padding="16dp"
            android:layout_marginTop="8dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="8dp">

                <ImageView
                    android:id="@+id/bonusIcon"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/ic_nav_quests"
                    android:layout_marginEnd="8dp"/>

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Glücksrad"
                    android:textColor="#FFFFFFFF"
                    android:textSize="18sp"
                    android:textStyle="bold"/>
            </LinearLayout>

            <TextView
                android:id="@+id/bonusDesc"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Schließe alle Aufgaben ab, um das Glücksrad zu drehen und ein Item zu gewinnen!"
                android:textColor="#BBBBBB"
                android:textSize="14sp"
                android:layout_marginBottom="12dp"/>

            <Button
                android:id="@+id/bonusButton"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:background="@drawable/buttonshape"
                android:backgroundTint="#424242"
                android:stateListAnimator="@animator/button_press"
                android:text="Alle Aufgaben abschließen"
                android:textColor="#9E9E9E"
                android:textSize="14sp"
                android:enabled="false"
                android:elevation="4dp"/>

            <TextView
                android:id="@+id/bonusCollectedText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Bonus gesammelt ✓"
                android:textColor="#7C4DFF"
                android:textSize="16sp"
                android:gravity="center"
                android:textStyle="bold"
                android:layout_marginTop="8dp"
                android:visibility="gone"/>

        </LinearLayout>

    </LinearLayout>
</ScrollView>
